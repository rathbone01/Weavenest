@using Weavenest.DataAccess.Models
@using Weavenest.DataAccess.Repositories
@using Weavenest.Services
@using Weavenest.Services.Interfaces
@using Weavenest.Components.Folders
@inject IChatRepository ChatRepo
@inject IFolderRepository FolderRepo
@inject ChatStateNotifier StateNotifier
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject IUserIdentityService UserIdentity
@implements IDisposable

<div style="display: flex; flex-direction: column; flex: 1; min-height: 0;">
    <div style="flex: 0 0 auto; padding: 8px; display: flex; flex-direction: column; gap: 4px;">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="StartNewChat">
            New Chat
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   FullWidth="true"
                   StartIcon="@Icons.Material.Filled.CreateNewFolder"
                   OnClick="CreateFolder">
            New Folder
        </MudButton>
        <MudTextField @bind-Value="_searchQuery"
                      Placeholder="Search chats..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      DebounceInterval="300"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Clearable="true"
                      OnClearButtonClick="ClearSearch"
                      Margin="Margin.Dense" />
    </div>

    <div style="flex: 1; overflow-y: auto; min-height: 0;">
        @if (_isSearching)
        {
            @if (_searchResults is not null && _searchResults.Any())
            {
                <MudNavMenu>
                    @foreach (var session in _searchResults)
                    {
                        @RenderSessionItem(session)
                    }
                </MudNavMenu>
            }
            else if (_searchResults is not null)
            {
                <MudText Typo="Typo.caption" Class="pa-4" Style="opacity: 0.5;">
                    No results found.
                </MudText>
            }
        }
        else
        {
            @if (_folders.Any() || _sessions.Any())
            {
                <MudNavMenu>
                    @foreach (var folder in _folders)
                    {
                        <div class="nav-folder-item">
                            <div class="folder-header" @onclick="() => ToggleFolder(folder.Id)">
                                <MudIcon Icon="@(_expandedFolders.Contains(folder.Id) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                         Size="Size.Small" Class="folder-chevron" />
                                <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Color="Color.Secondary" Class="mr-1" />
                                <MudText Typo="Typo.body2" Class="folder-name">@folder.Name</MudText>
                                <MudText Typo="Typo.caption" Style="opacity: 0.4; margin-left: auto; margin-right: 4px;">
                                    @SessionsInFolder(folder.Id).Count()
                                </MudText>
                            </div>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                     Class="folder-menu-btn" Dense="true" AnchorOrigin="Origin.BottomRight">
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => RenameFolder(folder))">
                                    Rename
                                </MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error"
                                             OnClick="@(() => DeleteFolder(folder))">
                                    Delete
                                </MudMenuItem>
                            </MudMenu>
                        </div>
                        @if (_expandedFolders.Contains(folder.Id))
                        {
                            <div class="folder-sessions">
                                @foreach (var session in SessionsInFolder(folder.Id))
                                {
                                    @RenderSessionItem(session)
                                }
                                @if (!SessionsInFolder(folder.Id).Any())
                                {
                                    <MudText Typo="Typo.caption" Class="pa-2 pl-6" Style="opacity: 0.4;">
                                        Empty folder
                                    </MudText>
                                }
                            </div>
                        }
                    }

                    @if (UnfiledSessions.Any())
                    {
                        @if (_folders.Any())
                        {
                            <MudDivider Class="my-1" />
                        }
                        @foreach (var session in UnfiledSessions)
                        {
                            @RenderSessionItem(session)
                        }
                    }
                </MudNavMenu>
            }
            else
            {
                <MudText Typo="Typo.caption" Class="pa-4" Style="opacity: 0.5;">
                    No chats yet. Start a new conversation!
                </MudText>
            }
        }
    </div>
</div>

@code {
    private IReadOnlyList<ChatSession> _sessions = [];
    private IReadOnlyList<Folder> _folders = [];
    private HashSet<Guid> _expandedFolders = [];
    private string _searchQuery = "";
    private IReadOnlyList<ChatSession>? _searchResults;
    private bool _isSearching => !string.IsNullOrWhiteSpace(_searchQuery);

    private IEnumerable<ChatSession> UnfiledSessions => _sessions.Where(s => s.FolderId is null);
    private IEnumerable<ChatSession> SessionsInFolder(Guid folderId) => _sessions.Where(s => s.FolderId == folderId);

    private RenderFragment RenderSessionItem(ChatSession session) => __builder =>
    {
        <div class="nav-session-item">
            <MudNavLink Href="@($"/chat/{session.Id}")"
                        Match="NavLinkMatch.All"
                        Class="session-link">
                <div class="session-content">
                    <MudText Typo="Typo.body2" Class="session-title">
                        @session.Title
                    </MudText>
                </div>
            </MudNavLink>
            <MudMenu Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small"
                     Class="move-btn" Dense="true" AnchorOrigin="Origin.BottomRight">
                @if (session.FolderId is not null)
                {
                    <MudMenuItem Icon="@Icons.Material.Filled.FolderOff"
                                 OnClick="@(() => MoveToFolder(session.Id, null))">
                        Remove from folder
                    </MudMenuItem>
                    <MudDivider />
                }
                @foreach (var folder in _folders)
                {
                    <MudMenuItem Icon="@Icons.Material.Filled.Folder"
                                 Disabled="@(session.FolderId == folder.Id)"
                                 OnClick="@(() => MoveToFolder(session.Id, folder.Id))">
                        @folder.Name
                    </MudMenuItem>
                }
                @if (!_folders.Any())
                {
                    <MudMenuItem Disabled="true">No folders yet</MudMenuItem>
                }
            </MudMenu>
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Size="Size.Small"
                           Color="Color.Error"
                           Class="delete-btn"
                           OnClick="@(() => DeleteSession(session.Id))" />
        </div>
    };

    protected override async Task OnInitializedAsync()
    {
        StateNotifier.OnSessionsChanged += OnSessionsChanged;
        await RefreshSessions();
    }

    private async Task OnSessionsChanged()
    {
        await InvokeAsync(async () =>
        {
            await RefreshSessions();
            StateHasChanged();
        });
    }

    private async Task RefreshSessions()
    {
        var userId = await UserIdentity.GetCurrentUserIdAsync();
        if (userId is null)
        {
            _sessions = [];
            _folders = [];
            return;
        }
        _sessions = await ChatRepo.GetSessionsAsync(userId.Value);
        _folders = await FolderRepo.GetFoldersByUserAsync(userId.Value);
    }

    private void StartNewChat()
    {
        Navigation.NavigateTo("/chat");
    }

    private async Task DeleteSession(Guid sessionId)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Chat",
            "Are you sure you want to delete this chat?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            await ChatRepo.DeleteSessionAsync(sessionId);
            await RefreshSessions();
            StateHasChanged();

            var currentUri = Navigation.Uri;
            if (currentUri.Contains(sessionId.ToString()))
            {
                Navigation.NavigateTo("/chat");
            }
        }
    }

    private async Task MoveToFolder(Guid sessionId, Guid? folderId)
    {
        if (folderId.HasValue)
            await ChatRepo.AddSessionToFolderAsync(sessionId, folderId.Value);
        else
            await ChatRepo.RemoveSessionFromFolderAsync(sessionId);

        await RefreshSessions();
        StateHasChanged();
    }

    private void ToggleFolder(Guid folderId)
    {
        if (!_expandedFolders.Remove(folderId))
            _expandedFolders.Add(folderId);
    }

    private async Task CreateFolder()
    {
        var userId = await UserIdentity.GetCurrentUserIdAsync();
        if (userId is null) return;

        var parameters = new DialogParameters
        {
            ["Title"] = "Create Folder"
        };

        var dialog = await DialogService.ShowAsync<FolderDialog>("Create Folder", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is string name)
        {
            await FolderRepo.CreateFolderAsync(userId.Value, name);
            await RefreshSessions();
            StateHasChanged();
        }
    }

    private async Task RenameFolder(Folder folder)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Rename Folder",
            ["InitialName"] = folder.Name
        };

        var dialog = await DialogService.ShowAsync<FolderDialog>("Rename Folder", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is string newName)
        {
            await FolderRepo.RenameFolderAsync(folder.Id, newName);
            await RefreshSessions();
            StateHasChanged();
        }
    }

    private async Task DeleteFolder(Folder folder)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Folder",
            $"Are you sure you want to delete \"{folder.Name}\"? Chats in this folder will be moved to unfiled.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            await FolderRepo.DeleteFolderAsync(folder.Id);
            _expandedFolders.Remove(folder.Id);
            await RefreshSessions();
            StateHasChanged();
        }
    }

    private async Task OnSearchChanged(string query)
    {
        _searchQuery = query;
        if (string.IsNullOrWhiteSpace(query))
        {
            _searchResults = null;
            return;
        }

        var userId = await UserIdentity.GetCurrentUserIdAsync();
        if (userId is null) return;

        _searchResults = await ChatRepo.SearchSessionsAsync(userId.Value, query);
        StateHasChanged();
    }

    private void ClearSearch()
    {
        _searchQuery = "";
        _searchResults = null;
    }

    public void Dispose()
    {
        StateNotifier.OnSessionsChanged -= OnSessionsChanged;
    }
}
