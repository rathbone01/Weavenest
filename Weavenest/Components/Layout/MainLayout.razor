@inherits LayoutComponentBase
@using Weavenest.Configuration
@using Weavenest.Components.Mind
@using Weavenest.Services.Models.Options
@using Microsoft.Extensions.Options
@inject IOptions<OllamaOptions> OllamaOptions

<MudThemeProvider IsDarkMode="true" Theme="WeavenestTheme.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6" Class="ml-3">Jeremy</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">@OllamaOptions.Value.Model</MudText>
        <MudSpacer />
        <EmotionalStateDisplay />
    </MudAppBar>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>
