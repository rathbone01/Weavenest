@using Weavenest.DataAccess.Models
@using Markdig
@inject IJSRuntime JSRuntime

<div class="chat-bubble">
    <div class="role-header">
        <span class="role-label @RoleLabelClass">@RoleLabel</span>
        <span class="message-timestamp">@Message.Timestamp.ToLocalTime().ToString("h:mm tt")</span>
    </div>
    @if (Message.Role == ChatRole.Assistant && !string.IsNullOrEmpty(Message.Thinking))
    {
        <div class="thinking-section">
            <button class="thinking-toggle" @onclick="ToggleThinking">
                <MudIcon Icon="@Icons.Material.Filled.Psychology" Size="Size.Small" Class="thinking-icon" />
                <span class="thinking-label">
                    @if (IsStreaming && string.IsNullOrEmpty(Message.Content))
                    {
                        <span>Thinking<span class="thinking-ellipsis">...</span></span>
                    }
                    else
                    {
                        <span>Thought process</span>
                    }
                </span>
                <MudIcon Icon="@(_thinkingExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                         Size="Size.Small" Class="thinking-chevron" />
            </button>
            @if (_thinkingExpanded)
            {
                <div class="thinking-full" @ref="_thinkingFullEl">@Message.Thinking</div>
            }
            else
            {
                <div class="thinking-preview">@ThinkingPreview</div>
            }
        </div>
    }
    <MudPaper Class="@($"chat-bubble-paper {PaperClass}")" Elevation="1">
        @if (Message.Role == ChatRole.User)
        {
            <div class="message-content-plain">&nbsp; @Message.Content</div>
        }
        else
        {
            <div class="markdown-body">
                @((MarkupString)RenderMarkdown(Message.Content))
                @if (IsStreaming && string.IsNullOrEmpty(Message.Content))
                {
                    <span class="cursor-blink">|</span>
                }
            </div>
            @if (IsStreaming && !string.IsNullOrEmpty(Message.Content))
            {
                <span class="cursor-blink streaming-cursor">|</span>
            }
        }
    </MudPaper>
</div>

@code {
    [Parameter, EditorRequired]
    public ChatMessage Message { get; set; } = default!;

    [Parameter]
    public bool IsStreaming { get; set; }

    private bool _thinkingExpanded;
    private ElementReference _thinkingFullEl;

    private void ToggleThinking() => _thinkingExpanded = !_thinkingExpanded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsStreaming && _thinkingExpanded && !string.IsNullOrEmpty(Message.Thinking))
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("chatInterop.scrollToBottom", _thinkingFullEl);
            }
            catch { /* ignore JS interop errors during disconnect */ }
        }
    }

    private string ThinkingPreview => Message.Thinking is { Length: > 120 }
        ? Message.Thinking[..120] + "…"
        : Message.Thinking ?? "";

    private static readonly MarkdownPipeline _pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private string RoleLabel => Message.Role == ChatRole.User
        ? "You"
        : Message.ModelName is not null
            ? $"Weavenest - {Message.ModelName}"
            : "Weavenest";

    private string RoleLabelClass => Message.Role == ChatRole.User
        ? "role-label-user"
        : "role-label-assistant";

    private string PaperClass => Message.Role == ChatRole.User
        ? "user-paper"
        : "assistant-paper";

    private static string RenderMarkdown(string content) =>
        Markdown.ToHtml(content, _pipeline);
}
