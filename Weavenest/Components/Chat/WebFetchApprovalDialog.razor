@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.OpenInBrowser" Class="mr-2" />
            Web Page Access
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-3" Dense="false">
            Only allow domains you recognize and trust. Do not approve unknown, unverified,
            or suspicious URLs — malicious web pages can attempt to manipulate AI behavior.
        </MudAlert>
        <MudText Typo="Typo.body1" Class="mb-2">
            The assistant wants to fetch content from:
        </MudText>
        <MudText Typo="Typo.body2" Class="ml-2" Style="word-break: break-all; opacity: 0.85;">
            @Url
        </MudText>
        @if (IsDeepResearch)
        {
            <MudCheckBox @bind-Value="_trustAll" Color="Color.Warning" Class="mt-3"
                         Label="Trust all domains for this research run" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Deny" Color="Color.Default" Variant="Variant.Text">Deny</MudButton>
        <MudButton OnClick="AllowForSession" Color="Color.Primary" Variant="Variant.Filled">
            Allow for this session
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Url { get; set; } = "";

    [Parameter]
    public bool IsDeepResearch { get; set; }

    private bool _trustAll;

    private void Deny() => MudDialog.Close(DialogResult.Ok(false));

    private void AllowForSession() => MudDialog.Close(
        _trustAll ? DialogResult.Ok("trust_all") : DialogResult.Ok(true));
}
