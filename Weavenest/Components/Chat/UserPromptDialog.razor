@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Psychology" Class="mr-2" />
            User Memory
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3" Style="opacity: 0.7;">
            Personal instructions applied to every conversation. Tell the assistant about
            your preferences, context, or how you like responses formatted.
        </MudText>
        <MudTextField @bind-Value="UserPrompt"
                      Placeholder="e.g. I'm a C# developer. I prefer concise answers with code examples."
                      Variant="Variant.Outlined"
                      Lines="5"
                      Sizing="InputSizing.Auto"
                      MaxLines="12"
                      Label="User Memory"
                      FullWidth="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Clear" Color="Color.Error" Variant="Variant.Text">Clear</MudButton>
        <MudSpacer />
        <MudButton OnClick="Cancel" Color="Color.Default" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string? UserPrompt { get; set; }

    private void Save() => MudDialog.Close(DialogResult.Ok(UserPrompt));

    private void Cancel() => MudDialog.Cancel();

    private void Clear()
    {
        UserPrompt = null;
        MudDialog.Close(DialogResult.Ok<string?>(null));
    }
}
