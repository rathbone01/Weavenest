@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-2" />
            Change Password
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3" Style="opacity: 0.7;">
            Changing your password will re-encrypt all of your chat data with a new key.
            This may take a moment if you have many conversations.
        </MudText>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
        }

        <MudTextField @bind-Value="_currentPassword"
                      Label="Current Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="mb-3" />

        <MudTextField @bind-Value="_newPassword"
                      Label="New Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="mb-3" />

        <MudTextField @bind-Value="_confirmPassword"
                      Label="Confirm New Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      FullWidth="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default" Variant="Variant.Text" Disabled="_isProcessing">Cancel</MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary" Variant="Variant.Filled" Disabled="_isProcessing">
            @if (_isProcessing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Re-encrypting...</span>
            }
            else
            {
                <span>Change Password</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid UserId { get; set; }

    [Parameter]
    public Func<Guid, string, string, Task<(bool Success, string? Error)>>? OnChangePassword { get; set; }

    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _error;
    private bool _isProcessing;

    private async Task Submit()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_currentPassword))
        {
            _error = "Current password is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _error = "New password is required.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _error = "New passwords do not match.";
            return;
        }

        if (_newPassword == _currentPassword)
        {
            _error = "New password must be different from current password.";
            return;
        }

        _isProcessing = true;
        StateHasChanged();

        try
        {
            if (OnChangePassword is not null)
            {
                var (success, error) = await OnChangePassword(UserId, _currentPassword, _newPassword);
                if (!success)
                {
                    _error = error ?? "Failed to change password.";
                    return;
                }
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _error = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
