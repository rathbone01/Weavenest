@using Weavenest.Services.Models
@using MudBlazor

<div class="tool-message-bubble">
    <div class="tool-header">
        <MudIcon Icon="@ToolIcon" Size="Size.Small" Class="tool-icon" />
        <span class="tool-label">@HeaderText</span>
        <span class="tool-timestamp">@Message.Timestamp.ToLocalTime().ToString("h:mm tt")</span>
    </div>
    <MudPaper Class="tool-paper" Elevation="0">
        <MudText Typo="Typo.body2" Class="tool-content">
            @Message.Content
        </MudText>
    </MudPaper>
</div>

@code {
    [Parameter, EditorRequired]
    public AgenticDisplayMessage Message { get; set; } = default!;

    private string ToolIcon => Message.Role == "tool_call"
        ? Icons.Material.Filled.Build
        : Icons.Material.Filled.Description;

    private string HeaderText => Message.Role == "tool_call"
        ? Message.ToolName switch
        {
            "web_search" => "Web Search",
            "web_fetch" => "Fetching Page",
            _ => $"Calling {Message.ToolName}..."
        }
        : Message.ToolName switch
        {
            "web_search" => "Search Results",
            "web_fetch" => "Page Content",
            _ => $"Result from {Message.ToolName}"
        };
}
