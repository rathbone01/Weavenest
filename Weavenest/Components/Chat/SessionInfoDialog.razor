@using MudBlazor
@using Weavenest.DataAccess.Repositories
@using Weavenest.Services.Models
@inject IChatRepository ChatRepo

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.ManageHistory" Class="mr-2" />
            Session Activity
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="false">

            <MudTabPanel Text="Tool Calls" Icon="@Icons.Material.Filled.Build"
                         BadgeData="@(ToolCallCount > 0 ? ToolCallCount : null)"
                         BadgeColor="Color.Primary">
                @if (ToolCallCount == 0)
                {
                    <MudText Typo="Typo.body2" Style="opacity: 0.5;">
                        No tool calls yet this session.
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="mb-2" Style="opacity: 0.5;">
                        All web searches and page fetches made by the assistant this session.
                    </MudText>
                    <div class="tool-call-list">
                        @foreach (var call in ToolCalls.Where(m => m.Role == "tool_call"))
                        {
                            <div class="tool-call-item">
                                <MudIcon Icon="@(call.ToolName == "web_search" ? Icons.Material.Filled.Search : Icons.Material.Filled.OpenInBrowser)"
                                         Size="Size.Small" Class="tool-call-icon" />
                                <div class="tool-call-text">
                                    <span class="tool-call-label">
                                        @(call.ToolName == "web_search" ? "Web Search" : "Page Fetch")
                                    </span>
                                    <span class="tool-call-content">@call.Content</span>
                                </div>
                                <span class="tool-call-time">@call.Timestamp.ToLocalTime().ToString("h:mm tt")</span>
                            </div>
                        }
                    </div>
                }
            </MudTabPanel>

            <MudTabPanel Text="Approved Sites" Icon="@Icons.Material.Filled.Shield"
                         BadgeData="@(WhitelistedDomains.Count > 0 ? WhitelistedDomains.Count : null)"
                         BadgeColor="Color.Success">
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    Approved sites are saved per chat. The assistant can fetch pages from these domains
                    without prompting you again in this conversation.
                </MudAlert>
                @if (WhitelistedDomains.Count == 0)
                {
                    <MudText Typo="Typo.body2" Style="opacity: 0.5;">
                        No sites approved for this chat. You'll be asked before any page is fetched.
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="mb-2" Style="opacity: 0.5;">
                        The assistant can fetch pages from these domains without prompting you.
                    </MudText>
                    <div class="whitelist-list">
                        @foreach (var domain in WhitelistedDomains.ToList())
                        {
                            <div class="whitelist-item">
                                <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" Class="whitelist-icon" />
                                <span class="whitelist-domain">@domain</span>
                                <MudTooltip Text="Remove — you'll be prompted again before fetching from this domain">
                                    <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => RemoveDomain(domain))" />
                                </MudTooltip>
                            </div>
                        }
                    </div>
                    <MudButton StartIcon="@Icons.Material.Filled.ClearAll"
                               Color="Color.Error"
                               Variant="Variant.Text"
                               Size="Size.Small"
                               Class="mt-2"
                               OnClick="ClearAllDomains">
                        Remove all approved sites
                    </MudButton>
                }
            </MudTabPanel>

        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public List<AgenticDisplayMessage> ToolCalls { get; set; } = [];

    [Parameter]
    public HashSet<string> WhitelistedDomains { get; set; } = [];

    [Parameter]
    public Guid SessionId { get; set; }

    private int ToolCallCount => ToolCalls.Count(m => m.Role == "tool_call");

    private async Task RemoveDomain(string domain)
    {
        WhitelistedDomains.Remove(domain);
        await ChatRepo.RemoveWhitelistedDomainAsync(SessionId, domain);
        StateHasChanged();
    }

    private async Task ClearAllDomains()
    {
        WhitelistedDomains.Clear();
        await ChatRepo.ClearWhitelistedDomainsAsync(SessionId);
        StateHasChanged();
    }

    private void Close() => MudDialog.Close();
}
