@using MudBlazor

<MudTooltip Text="@TooltipText">
    <MudChip T="string"
             Color="@ChipColor"
             Variant="Variant.Outlined"
             Size="Size.Small">
        <MudIcon Icon="@Icons.Material.Filled.Memory" Size="Size.Small" Class="mr-1" />
        @UsageText
    </MudChip>
</MudTooltip>

@code {
    [Parameter] public int EstimatedTokens { get; set; }
    [Parameter] public int ContextLength { get; set; }

    private double UsagePercent => ContextLength > 0
        ? (double)EstimatedTokens / ContextLength * 100
        : 0;

    private string UsageText => $"~{EstimatedTokens:N0} / {ContextLength:N0}";

    private string TooltipText =>
        $"Estimated token usage: {UsagePercent:F1}% of context window ({ContextLength:N0} tokens)";

    private Color ChipColor => UsagePercent switch
    {
        > 90 => Color.Error,
        > 70 => Color.Warning,
        _ => Color.Default
    };
}
