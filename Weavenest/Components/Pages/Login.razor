@page "/"
@page "/login"
@layout AuthLayout
@attribute [AllowAnonymous]
@using Weavenest.Services
@using Weavenest.Services.Interfaces
@inject IAuthService AuthService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Login - Weavenest</PageTitle>

<div class="login-wrap">
    <div class="login-logo">
        <WeavenestLogo Size="220" ShowWordmark="true" InlineWords="true" />
    </div>
    <MudCard class="login-card" Style="width: 400px;">
    <MudCardContent>
        <MudTextField Label="Username"
                      @bind-Value="_username"
                      Immediate="true"
                      Variant="Variant.Outlined"
                      Class="mb-3"
                      OnKeyDown="HandleKeyDown" />
        <MudTextField Label="Password"
                      @bind-Value="_password"
                      Immediate="true"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      OnKeyDown="HandleKeyDown" />
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-4">@_errorMessage</MudAlert>
        }
    </MudCardContent>
    <MudCardActions Class="d-flex flex-column pa-4 pt-0">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="HandleLogin"
                   Disabled="_isLoading">
            @if (_isLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Login
        </MudButton>
        <MudLink Href="/register" Class="mt-3 align-self-center" Typo="Typo.body2">
            Don't have an account? Sign up
        </MudLink>
    </MudCardActions>
    </MudCard>
</div>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
            Navigation.NavigateTo("/chat", replace: true);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandleLogin();
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            var (token, error) = await AuthService.LoginAsync(_username, _password);
            if (token is null)
            {
                _errorMessage = error ?? "Invalid username or password.";
                return;
            }

            await AuthStateProvider.Login(token);
            Navigation.NavigateTo("/chat");
        }
        finally
        {
            _isLoading = false;
        }
    }
}
