@page "/chat/{SessionId:guid?}"
@using Weavenest.DataAccess.Models
@using Weavenest.DataAccess.Repositories
@using Weavenest.Services
@using Weavenest.Services.Interfaces
@using Weavenest.Services.Models
@inject IOllamaService OllamaService
@inject IAgenticChatService AgenticChat
@inject IChatRepository ChatRepo
@inject ChatStateNotifier StateNotifier
@inject CircuitSettings Settings
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ILogger<Chat> Logger
@inject IUserIdentityService UserIdentity
@inject IUserRepository UserRepo
@implements IDisposable

<PageTitle>Chat - Weavenest</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <MudSelect T="string" Value="_selectedModel" Label="Model"
                   Variant="Variant.Outlined" Dense="true" Class="model-select"
                   ValueChanged="OnModelChanged">
            @foreach (var model in _availableModels)
            {
                <MudSelectItem Value="@model">@model</MudSelectItem>
            }
        </MudSelect>
        <MudSpacer />
        <div class="context-display-wrapper">
            <ContextWindowDisplay EstimatedTokens="_estimatedTokenCount"
                                  ContextLength="_contextLength" />
        </div>
        <MudTooltip Text="@SessionActivityTooltip">
            <MudBadge Content="@SessionActivityBadge" Color="Color.Primary"
                      Visible="@(_displayMessages.Count > 0 || _sessionWhitelistedDomains.Count > 0)"
                      Overlap="true" Dot="false">
                <MudIconButton Icon="@Icons.Material.Filled.ManageHistory"
                               Color="@(_displayMessages.Count > 0 || _sessionWhitelistedDomains.Count > 0 ? Color.Primary : Color.Default)"
                               OnClick="OpenSessionInfoDialog"
                               Class="ml-1" />
            </MudBadge>
        </MudTooltip>
        <MudTooltip Text="@UserPromptTooltip">
            <MudIconButton Icon="@Icons.Material.Filled.Psychology"
                           Color="@(!string.IsNullOrWhiteSpace(Settings.UserPrompt) ? Color.Primary : Color.Default)"
                           OnClick="OpenUserMemoryDialog"
                           Class="ml-1" />
        </MudTooltip>
        <MudMenu Icon="@Icons.Material.Filled.Settings" AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight" Dense="true">
            <MudMenuItem OnClick="ToggleShowThinking"
                         Disabled="@(!_modelSupportsThinking)"
                         Icon="@(_showThinking && _modelSupportsThinking ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)"
                         IconColor="@(_showThinking && _modelSupportsThinking ? Color.Primary : Color.Default)">
                Show Thinking
            </MudMenuItem>
        </MudMenu>
    </div>

    @if (_ollamaError is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-2">@_ollamaError</MudAlert>
    }

    <div class="chat-messages" @ref="_messagesContainer">
        @foreach (var message in GetSessionMessagesForRender())
        {
            <ChatBubble Message="message" ShowThinking="_showThinking" />
        }
        @if (_isStreaming && _currentSession?.Id == _processingSessionId)
        {
            <ChatBubble Message="@_streamingMessage" IsStreaming="true" ShowThinking="_showThinking" />
        }
        @if (IsViewingProcessingSession && _deepResearchWasActive && _displayMessages.Any(dm => dm.EventType is not null))
        {
            @if (_deepResearchComplete)
            {
                <MudExpansionPanels Class="my-2">
                    <MudExpansionPanel Text="Research Activity Log"
                                       Icon="@Icons.Material.Filled.Science"
                                       Expanded="false">
                        <MudList T="string" Dense="true">
                            @foreach (var dm in _displayMessages.Where(d => d.EventType is not null))
                            {
                                <MudListItem T="string" Icon="@GetResearchEventIcon(dm.EventType!)"
                                             IconColor="Color.Primary">
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.5; white-space: nowrap;">
                                            @dm.Timestamp.ToLocalTime().ToString("h:mm:ss tt")
                                        </MudText>
                                        <MudText Typo="Typo.body2">@dm.Content</MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }
            else
            {
                <MudPaper Class="research-feed-panel my-2" Elevation="1">
                    <div class="research-feed-header">
                        <MudIcon Icon="@Icons.Material.Filled.Science" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.subtitle2">Research in Progress</MudText>
                        <MudSpacer />
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    </div>
                    <div class="research-feed-list" @ref="_researchFeedContainer">
                        <MudList T="string" Dense="true">
                            @foreach (var dm in _displayMessages.Where(d => d.EventType is not null))
                            {
                                <MudListItem T="string" Icon="@GetResearchEventIcon(dm.EventType!)"
                                             IconColor="Color.Primary">
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.5; white-space: nowrap;">
                                            @dm.Timestamp.ToLocalTime().ToString("h:mm:ss tt")
                                        </MudText>
                                        <MudText Typo="Typo.body2">@dm.Content</MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    </div>
                </MudPaper>
            }
        }
        @if (!IsViewingProcessingSession || !_deepResearchWasActive)
        {
            @foreach (var dm in _displayMessages)
            {
                @if (dm.Role is "tool_call" or "tool_result")
                {
                    <ToolMessageBubble Message="dm" />
                }
                else if (dm.Role == "assistant")
                {
                    <ChatBubble Message="@(new ChatMessage
                    {
                        Role = ChatRole.Assistant,
                        Content = dm.Content,
                        ModelName = dm.ModelName,
                        Timestamp = dm.Timestamp
                    })" ShowThinking="_showThinking" />
                }
            }
        }
        @{var deferred = GetDeferredAssistantMessage();}
        @if (deferred is not null)
        {
            @if (_deepResearchComplete)
            {
                <ResearchReportCard Content="@deferred.Content" Timestamp="@deferred.Timestamp" />
            }
            else
            {
                <ChatBubble Message="deferred" ShowThinking="_showThinking" />
            }
        }
        @if (IsViewingProcessingSession && !_isStreaming && !(_deepResearchWasActive && _displayMessages.Any(dm => dm.EventType is not null)))
        {
            <div class="processing-indicator">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Class="ml-2" Style="opacity: 0.5;">
                    Thinking...
                </MudText>
            </div>
        }
        @if (!_isProcessing && !_isStreaming && _displayMessages.Count == 0 && (_currentSession is null || !_currentSession.Messages.Any()))
        {
            <div class="chat-empty-state">
                <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Large" Style="opacity: 0.3;" />
                <MudText Typo="Typo.h6" Style="opacity: 0.4;" Class="mt-2">Start a conversation</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.3;">Type a message below to begin</MudText>
            </div>
        }
    </div>

    <div class="chat-input-area">
        <div class="chat-input-chips">
            <MudChip T="string"
                     Color="@(_webSearchEnabled ? Color.Primary : Color.Default)"
                     Variant="@(_webSearchEnabled ? Variant.Filled : Variant.Outlined)"
                     Size="Size.Small"
                     Icon="@Icons.Material.Filled.TravelExplore"
                     OnClick="ToggleWebSearch"
                     Disabled="@(_isProcessing || !_modelSupportsTools)"
                     Class="deep-research-chip">
                Web Search
            </MudChip>
            <MudTooltip Text="@(_webSearchEnabled ? "" : "Enable web search to use deep research")"
                        Disabled="@_webSearchEnabled">
                <MudChip T="string"
                         Color="@(_deepResearchEnabled ? Color.Warning : Color.Default)"
                         Variant="@(_deepResearchEnabled ? Variant.Filled : Variant.Outlined)"
                         Size="Size.Small"
                         Icon="@Icons.Material.Filled.Science"
                         OnClick="ToggleDeepResearch"
                         Disabled="@(_isProcessing || !_modelSupportsTools || !_webSearchEnabled)"
                         Class="deep-research-chip">
                    Deep Research
                </MudChip>
            </MudTooltip>
        </div>
        <MudTextField @bind-Value="_userInput"
                      Placeholder="Type your message... (Shift+Enter for new line)"
                      Variant="Variant.Outlined"
                      Lines="2"
                      Sizing="InputSizing.Auto"
                      MaxLines="5"
                      Adornment="Adornment.End"
                      AdornmentIcon="@InputAdornmentIcon"
                      AdornmentColor="@InputAdornmentColor"
                      AdornmentAriaLabel="@InputAdornmentLabel"
                      OnAdornmentClick="HandleAdornmentClick"
                      OnKeyDown="HandleKeyDown"
                      Immediate="true" />
    </div>
</div>
