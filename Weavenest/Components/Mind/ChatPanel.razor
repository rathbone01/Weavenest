@using Weavenest.Services
@inject MindStateService MindState
@inject IJSRuntime JS
@implements IDisposable

<div class="chat-panel">
    <div class="chat-header">
        <MudText Typo="Typo.subtitle1" Color="Color.Primary">Conversation</MudText>
    </div>

    <div class="chat-messages" @ref="_messagesContainer">
        @if (_messages.Count == 0)
        {
            <div class="chat-empty">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Waiting for Jeremy to speak...
                </MudText>
            </div>
        }
        else
        {
            @foreach (var msg in _messages)
            {
                <div class="message-bubble @(msg.IsHuman ? "human" : "mind")">
                    <div class="message-header">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(msg.IsHuman ? "You" : "Jeremy") — @msg.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                        </MudText>
                    </div>
                    <MudText Typo="Typo.body2" Class="message-content">@msg.Content</MudText>
                </div>
            }
        }
    </div>

    <div class="chat-input-area" @ref="_inputContainer">
        <MudTextField Value="_userInput"
                      ValueChanged="@((string v) => OnInputChanged(v))"
                      Placeholder="Type a message... (Enter to send, Shift+Enter for new line)"
                      Variant="Variant.Outlined"
                      Lines="2"
                      MaxLines="4"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.Send"
                      AdornmentColor="Color.Primary"
                      OnAdornmentClick="SendMessage"
                      FullWidth />
    </div>
</div>

@code {
    private record ChatMessage(string Content, bool IsHuman, DateTime Timestamp);

    private readonly List<ChatMessage> _messages = [];
    private string _userInput = "";
    private ElementReference _messagesContainer;
    private ElementReference _inputContainer;
    private DotNetObjectReference<ChatPanel>? _dotnetRef;

    protected override void OnInitialized()
    {
        MindState.OnSpoke += HandleSpoke;

        foreach (var msg in MindState.GetHumanMessages())
            _messages.Add(new ChatMessage(msg, true, DateTime.Now));
        foreach (var msg in MindState.GetSpokenMessages())
            _messages.Add(new ChatMessage(msg, false, DateTime.Now));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("chatInterop.registerEnterSend", _inputContainer, _dotnetRef); }
            catch { }
        }
    }

    private void OnInputChanged(string value)
    {
        _userInput = value;
        MindState.SetUserTyping(!string.IsNullOrEmpty(value));
    }

    [JSInvokable]
    public async Task SendMessageFromJs(string value)
    {
        _userInput = value;
        await SendMessage();
    }

    private async Task HandleSpoke(string message)
    {
        _messages.Add(new ChatMessage(message, false, DateTime.Now));
        await InvokeAsync(StateHasChanged);
        await ScrollToBottom();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_userInput)) return;

        var content = _userInput.Trim();
        _userInput = "";
        MindState.SetUserTyping(false); // Clear gate so next tick fires immediately

        _messages.Add(new ChatMessage(content, true, DateTime.Now));
        await MindState.EnqueueHumanMessageAsync(content);

        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("chatInterop.scrollToBottom", _messagesContainer);
        }
        catch { }
    }

    public void Dispose()
    {
        MindState.OnSpoke -= HandleSpoke;
        _dotnetRef?.Dispose();
    }
}
