@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_folderName"
                      Label="Folder Name"
                      Variant="Variant.Outlined"
                      Immediate="true"
                      OnKeyDown="HandleKeyDown" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="string.IsNullOrWhiteSpace(_folderName)">
            OK
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string Title { get; set; } = "Folder";

    [Parameter]
    public string? InitialName { get; set; }

    private string _folderName = string.Empty;

    protected override void OnInitialized()
    {
        _folderName = InitialName ?? string.Empty;
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_folderName))
            Submit();
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(_folderName.Trim()));
    private void Cancel() => MudDialog.Cancel();
}
